{% include 'header.twig' %}

    <div class="home-head">
        <div class="home-head-bg"></div>
              <div class="shapeBox">  
				<img class="shape shape1" src="../img/shape1.png" />		       
				<img class="shape shape2" src="../img/shape2.png" />		       
				<img class="shape shape3" src="../img/shape3.png" />		       
              </div>	
        <div class="home-head-content">
            <div class="container" style="position: relative;">
                <div class="row">
                    <div class="col-lg-6 col-12 d-none d-lg-block">
                        <div class="hh-left-badge">
                            <div class="hhlb-icon">
                                <i class="fas fa-crown"></i>
                            </div>
                            <div class="hhlb-text">
                              Arzon va sifatli xizmatlar
                            </div>
                        </div>
						<h1 class="hl-title">
                            Uzbekistondagi eng arzon va sifatli nakrutka xizmati!
                        </h1>
						<div class="hl-text"><p style="color: #ffffff">
                        Ijtimoiy tarmoqlardagi obunachilarni, yoqtirishlarni, ko'rishlarni sotib oling, tezkor arzon sifatli!.
Bizda hamma ijtimoiy tarmoqga xizmatlarimiz mavjud! 
                 
                            </p>
                            
                        </div>
						<div class="hl-btns">
                            <a href="/services" class="btn btn-lg btn-outline">
                                <i class="fas fa-layer-group mr-2"></i> Xizmatlarni ko'rish
                            </a>
                        </div>
                    </div>
                    <div class="col-lg-5 offset-lg-1">
                        <div class="loginSide">
							<div class="round"></div>
                            <div class="login-box">
								  {% if errorText %}
									<div class="alert alert-dismissible alert-danger">
									  <button type="button" class="close" data-dismiss="alert">×</button>
									  {{ errorText }}
									</div>
								  {% endif %}
								  {% if successText %}
									<div class="alert alert-dismissible alert-success">
									  <button type="button" class="close" data-dismiss="alert">×</button>
									  {{ successText }}
									</div>
								  {% endif %}
                                <div class="lgb-title">
                                    Saytimizga xush kelibsiz!!
                                </div>
                                <div class="lgb-text">Kirish uchun login parol kiriting!</div>
								<form  method="post" action="">
                                <div class="fc-home">
                                    <label for="loginUsername"><span class="label-text">{{ lang['signin.username'] }}</span></label>
                                    <input type="text" id="loginUsername" name="username">
                                </div>
                                <div class="fc-home">
                                    <label for="loginPass"><span class="label-text">{{ lang['signin.password'] }}</span></label>
                                    <input type="password" id="loginPass" name="password">
                                </div>
                                <div class="form-row mt-2">
                                    <div class="col-6 py-2 mb-2">
										 <div class="form-check">
											<input type="checkbox"  name="LoginForm[remember]" value="1" id="remember">
											<label class="form-check-label" for="remember">Eslab qol</label>
										 </div>                                  
                                    </div>
                                    <div class="col-6 py-2 text-right">
                                        <a href="/resetpassword" class="frgpass">{{ lang['signin.password.lost'] }}</a>
                                    </div>
                                </div>
								  {% if captcha %}
									<div class="form-group">
									  <div class="g-recaptcha" data-sitekey="{{ captchaKey }}"></div>
									</div>
								  {% endif %}
                                <button class="btn btn-secondary btn-lg btn-block mt-3" type="submit">
                                   Kirish
                                </button>
								</form></br>
								<div class="lgb-text">
                                   Siz ro'yxatdan o'tmaganmisiz?
                                </div>
                                <div class="">
                                    <a href="/signup" class="btn btn-secondary btn-lg btn-block mt-3">
                                      <font color="#ffffff"><b>Yangi akkaunt ochish</b></font>
                                    </a></br>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="hs-area mb-5">
        <div class="container">
            <div class="hs-head">
				<h1>Eng arzon va sifatli nakrutka xizmatlari!</h1>
