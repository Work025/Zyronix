<script>

	if ($('.hs-area-owl').length) {
		$('.hs-area-owl').owlCarousel({
				loop:true,
				margin: 25,
				nav: false,
				dots: false,
				autoplay: 5000,
				responsive:{
					0:{
						items:1
					},
					600:{
						items:2
					},
					1000:{
						items:3
					}
				}
		});    		
	}
</script> 

 
